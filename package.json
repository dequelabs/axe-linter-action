{
  "name": "@deque/axe-linter-action",
  "version": "1.3.0",
  "private": true,
  "license": "MPL-2.0",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "ncc build src/index.ts --license licenses.txt -t",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "prepare": "husky",
    "test": "node --experimental-test-module-mocks --test 'src/**/*.test.ts'",
    "coverage": "node --experimental-test-module-mocks --test --experimental-test-coverage --test-coverage-lines=85 --test-coverage-branches=85 --test-coverage-functions=85 'src/**/*.test.ts'"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^24",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.20.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.23.0",
    "undici": "^7.24.5"
  }
}
