{
  "name": "@deque/axe-linter-action",
  "version": "1.3.0",
  "private": true,
  "license": "MPL-2.0",
  "scripts": {
    "prebuild": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "ncc build src/index.ts --license licenses.txt",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "prepare": "husky",
    "test": "node --experimental-config-file=node.config.json --test --experimental-test-coverage 'src/**/*.test.ts'"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^24",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.20.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0"
  }
}
